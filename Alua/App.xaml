<Application x:Class="Alua.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:controls="clr-namespace:Alua.UI.Controls">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Load Uno.UI.Toolkit resources -->
        <ToolkitResources xmlns="using:Uno.Toolkit.UI" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Add resources here -->
      <controls:BoolNegationToVisibilityConverter x:Key="BoolNegationToVisibilityConverter" />
      <!-- Appearance converters (used by inline page content such as the Settings preview; the
           Library card DataTemplates register their own copies per Uno's resource-scoping rule). -->
      <controls:BoolToVisibilityConverter x:Key="BoolToVisibility" />
      <controls:EnumToVisibilityConverter x:Key="EnumToVisibility" />
      <controls:CardTextAlignmentToTextAlignmentConverter x:Key="TextAlignToTextAlign" />
      <controls:CardTextAlignmentToHorizontalAlignmentConverter x:Key="TextAlignToHorizontal" />
      <controls:CompactToPaddingConverter x:Key="CompactToPadding" />

    </ResourceDictionary>
  </Application.Resources>

</Application>
