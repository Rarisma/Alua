<Page x:Class="Alua.UI.Library"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:Alua.Models"
      xmlns:android="http://uno.ui/android"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="android"
      xmlns:utu="using:Uno.Toolkit.UI"
      Loaded="OnLoaded"
      xmlns:controls="clr-namespace:Alua.UI.Controls"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Defined per-page (not app-level): Uno does not reliably resolve a {StaticResource}
             referenced inside a page-level DataTemplate up to Application.Resources, which left
             the ItemsRepeater templates unresolved and games rendering as raw "Alua.Models.Game". -->
        <controls:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <DataTemplate x:Key="GameTemplate" x:DataType="models:Game">
            <Grid Tapped="OpenGame" HorizontalAlignment="Stretch"
                  Padding="12" BorderThickness="1"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  CornerRadius="8"
                  MinHeight="120" MinWidth="300"
                  ColumnSpacing="12" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Game icon with provider badge -->
                <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border CornerRadius="6">
                        <controls:CachedImage UriSource="{x:Bind IconUri}" Stretch="Uniform"
                                              MaxWidth="140" MaxHeight="80"
                                              DecodePixelWidth="140" DecodePixelHeight="80"/>
                    </Border>
                    <controls:CachedImage UriSource="{x:Bind ProviderImageUri}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Opacity="0.6"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,2,2"/>
                </Grid>

                <!-- Game info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="2">
                    <TextBlock Text="{x:Bind Name}"
                               TextWrapping="Wrap" TextAlignment="Right"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                    <TextBlock Text="{x:Bind StatusText}"
                               TextAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind PlaytimeText}"
                               TextAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind HasPlaytime,
                               Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Achievement progress -->
                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                             Minimum="0" Maximum="{x:Bind Achievements.Count}"
                             Value="{x:Bind UnlockedCount}"
                             Height="6"
                             MinHeight="6"
                             CornerRadius="3"
                             Visibility="{x:Bind HasAchievements,
                             Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GameFillTemplate" x:DataType="models:Game">
            <Grid Tapped="OpenGame" HorizontalAlignment="Stretch"
                  BorderThickness="1"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  CornerRadius="8"
                  MinHeight="120" MinWidth="300">

                <!-- Filled-background progress indicator (drawn behind content) -->
                <Grid IsHitTestVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{x:Bind UnlockedColumnWidth, Mode=OneWay}"/>
                        <ColumnDefinition Width="{x:Bind LockedColumnWidth, Mode=OneWay}"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0"
                               Fill="{ThemeResource AccentFillColorDefaultBrush}"
                               Opacity="0.3"/>
                </Grid>

                <!-- Content layer -->
                <Grid Padding="12"
                      ColumnSpacing="12" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Game icon with provider badge -->
                    <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border CornerRadius="6">
                            <controls:CachedImage UriSource="{x:Bind IconUri}" Stretch="Uniform"
                                                  MaxWidth="140" MaxHeight="80"
                                                  DecodePixelWidth="140" DecodePixelHeight="80"/>
                        </Border>
                        <controls:CachedImage UriSource="{x:Bind ProviderImageUri}"
                                              Width="16" Height="16"
                                              Stretch="Uniform"
                                              Opacity="0.6"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,2,2"/>
                    </Grid>

                    <!-- Game info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" HorizontalAlignment="Stretch">
                        <TextBlock Text="{x:Bind Name}"
                                   TextWrapping="Wrap" TextAlignment="Right"
                                   MaxLines="2" TextTrimming="CharacterEllipsis"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="{x:Bind StatusText}" TextAlignment="Right"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind PlaytimeText}" TextAlignment="Right"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind HasPlaytime,
                                   Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <utu:LoadingView>
        <!-- Triggers for loading -->
        <utu:LoadingView.Source>
            <utu:CompositeLoadableSource>
                <utu:LoadableSource Source="{x:Bind RefreshCommand}" />
                <utu:LoadableSource Source="{x:Bind ScanCommand}" />
            </utu:CompositeLoadableSource>
        </utu:LoadingView.Source>
        <!-- Show loading spinner when refreshing or scanning new libraries -->
        <utu:LoadingView.LoadingContent>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="Updating games..." HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind _appVm.LoadingGamesSummary, Mode=OneWay}" HorizontalAlignment="Center"/>
                <!-- Cancel button shown during operations -->
                <Button Content="Cancel"
                        Command="{x:Bind CancelCommand}"
                        HorizontalAlignment="Center"
                        Visibility="{x:Bind _appVm.IsScanningOrRefreshing, Mode=OneWay,
                        Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </utu:LoadingView.LoadingContent>

        <RefreshContainer RefreshRequested="{x:Bind Refresh}">
            <Grid Padding="12,0,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ProfileCard stays outside the virtualized list -->
                <controls:ProfileCard Grid.Row="0" Margin="0,0,0,12"/>

                <!-- ItemsRepeater with swappable layouts for better performance -->
                <ScrollViewer x:Name="gamesScrollViewer"
                              Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled">
                    <ItemsRepeater Name="gameRepeater"
                                   ItemsSource="{x:Bind _appVm.FilteredGames, Mode=OneWay}"
                                   HorizontalAlignment="Stretch"/>
                </ScrollViewer>
            </Grid>
        </RefreshContainer>
    </utu:LoadingView>
</Page>
