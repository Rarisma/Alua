<Page x:Class="Alua.UI.Library"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:Alua.Models"
      xmlns:android="http://uno.ui/android"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="android"
      xmlns:utu="using:Uno.Toolkit.UI"
      Loaded="OnLoaded"
      xmlns:controls="clr-namespace:Alua.UI.Controls"
      xmlns:vm="clr-namespace:Alua.Services.ViewModels"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Defined per-page (not app-level): Uno does not reliably resolve a {StaticResource}
             referenced inside a page-level DataTemplate up to Application.Resources, which left
             the ItemsRepeater templates unresolved and games rendering as raw "Alua.Models.Game". -->
        <controls:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <controls:EnumToVisibilityConverter x:Key="EnumToVisibility"/>
        <controls:CardTextAlignmentToTextAlignmentConverter x:Key="TextAlignToTextAlign"/>
        <controls:CardTextAlignmentToHorizontalAlignmentConverter x:Key="TextAlignToHorizontal"/>
        <controls:CompactToPaddingConverter x:Key="CompactToPadding"/>

        <DataTemplate x:Key="GameTemplate" x:DataType="models:Game">
            <Grid Tapped="OpenGame" HorizontalAlignment="Stretch"
                  Padding="{Binding CompactCards, Source={StaticResource Settings}, Converter={StaticResource CompactToPadding}}"
                  BorderThickness="1"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  CornerRadius="8"
                  MinHeight="120" MinWidth="300"
                  ColumnSpacing="12" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Game icon with provider badge -->
                <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border CornerRadius="6">
                        <controls:CachedImage UriSource="{x:Bind IconUri}" Stretch="Uniform"
                                              MaxWidth="140" MaxHeight="80"
                                              DecodePixelWidth="140" DecodePixelHeight="80"/>
                    </Border>
                    <controls:CachedImage UriSource="{x:Bind ProviderImageUri}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Opacity="{Binding PlatformBadgeOpacity, Source={StaticResource Settings}}"
                                          Visibility="{Binding ShowPlatformBadge, Source={StaticResource Settings}, Converter={StaticResource BoolToVisibility}}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,2,2"/>
                </Grid>

                <!-- Game info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2"
                            HorizontalAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToHorizontal}}">
                    <TextBlock Text="{x:Bind DisplayName}"
                               TextWrapping="Wrap"
                               TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                               MaxLines="2" TextTrimming="CharacterEllipsis"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                    <TextBlock Text="{x:Bind EffectiveStatusText}"
                               TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind PlaytimeText}"
                               TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{Binding ShowPlaytimeOnCard, Source={StaticResource Settings}, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{x:Bind EditionsBadgeText}"
                               TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               Visibility="{x:Bind IsMerged,
                               Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Achievement progress (hidden when the progress style is None) -->
                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                             Minimum="0" Maximum="{x:Bind EffectiveTotal}"
                             Value="{x:Bind EffectiveUnlocked}"
                             Height="6"
                             MinHeight="6"
                             CornerRadius="3"
                             Visibility="{Binding CardProgressStyle, Source={StaticResource Settings}, ConverterParameter=Bar, Converter={StaticResource EnumToVisibility}}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GameFillTemplate" x:DataType="models:Game">
            <Grid Tapped="OpenGame" HorizontalAlignment="Stretch"
                  BorderThickness="1"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  CornerRadius="8"
                  MinHeight="120" MinWidth="300">

                <!-- Filled-background progress indicator (drawn behind content) -->
                <Grid IsHitTestVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{x:Bind UnlockedColumnWidth, Mode=OneWay}"/>
                        <ColumnDefinition Width="{x:Bind LockedColumnWidth, Mode=OneWay}"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0"
                               Fill="{ThemeResource AccentFillColorDefaultBrush}"
                               Opacity="0.3"/>
                </Grid>

                <!-- Content layer -->
                <Grid Padding="{Binding CompactCards, Source={StaticResource Settings}, Converter={StaticResource CompactToPadding}}"
                      ColumnSpacing="12" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Game icon with provider badge -->
                    <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border CornerRadius="6">
                            <controls:CachedImage UriSource="{x:Bind IconUri}" Stretch="Uniform"
                                                  MaxWidth="140" MaxHeight="80"
                                                  DecodePixelWidth="140" DecodePixelHeight="80"/>
                        </Border>
                        <controls:CachedImage UriSource="{x:Bind ProviderImageUri}"
                                              Width="16" Height="16"
                                              Stretch="Uniform"
                                              Opacity="{Binding PlatformBadgeOpacity, Source={StaticResource Settings}}"
                                              Visibility="{Binding ShowPlatformBadge, Source={StaticResource Settings}, Converter={StaticResource BoolToVisibility}}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,2,2"/>
                    </Grid>

                    <!-- Game info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2"
                                HorizontalAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToHorizontal}}">
                        <TextBlock Text="{x:Bind DisplayName}"
                                   TextWrapping="Wrap"
                                   TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                                   MaxLines="2" TextTrimming="CharacterEllipsis"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="{x:Bind EffectiveStatusText}"
                                   TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind PlaytimeText}"
                                   TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{Binding ShowPlaytimeOnCard, Source={StaticResource Settings}, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{x:Bind EditionsBadgeText}"
                                   TextAlignment="{Binding CardTextAlignment, Source={StaticResource Settings}, Converter={StaticResource TextAlignToTextAlign}}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                   Visibility="{x:Bind IsMerged,
                                   Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <utu:LoadingView>
        <!-- Triggers for loading -->
        <utu:LoadingView.Source>
            <utu:CompositeLoadableSource>
                <utu:LoadableSource Source="{x:Bind RefreshCommand}" />
                <utu:LoadableSource Source="{x:Bind ScanCommand}" />
            </utu:CompositeLoadableSource>
        </utu:LoadingView.Source>
        <!-- Show loading overlay with per-provider progress bars -->
        <utu:LoadingView.LoadingContent>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="400">
                <TextBlock Text="Updating games..." HorizontalAlignment="Center" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                
                <!-- Per-provider progress list -->
                <ItemsRepeater ItemsSource="{x:Bind _appVm.ProviderScanStatuses, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="4"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:AppVM+ProviderScanStatus">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="{x:Bind ProviderName}"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Status}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               HorizontalAlignment="Right"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <ProgressBar Minimum="0" Maximum="1"
                                             Value="{x:Bind Progress}"
                                             Height="4"
                                             CornerRadius="2"/>
                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="{x:Bind HasGames, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="{x:Bind GameCount}"/>
                                    <Run Text=" games"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                
                <!-- Additional summary text (e.g. HLTB fetch) -->
                <TextBlock Text="{x:Bind _appVm.LoadingGamesSummary, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                
                <!-- Cancel button shown during operations -->
                <Button Content="Cancel"
                        Command="{x:Bind CancelCommand}"
                        HorizontalAlignment="Center"
                        Visibility="{x:Bind _appVm.IsScanningOrRefreshing, Mode=OneWay,
                        Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </utu:LoadingView.LoadingContent>

        <RefreshContainer RefreshRequested="{x:Bind Refresh}">
            <Grid Padding="12,0,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ProfileCard stays outside the virtualized list -->
                <controls:ProfileCard Grid.Row="0" Margin="0,0,0,12"/>

                <!-- ItemsRepeater with swappable layouts for better performance -->
                <ScrollViewer x:Name="gamesScrollViewer"
                              Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled">
                    <ItemsRepeater Name="gameRepeater"
                                   ItemsSource="{x:Bind _appVm.FilteredGames, Mode=OneWay}"
                                   HorizontalAlignment="Stretch"/>
                </ScrollViewer>

                <!-- Empty state: no games scanned yet -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12" MaxWidth="320"
                            Visibility="{x:Bind _appVm.LibraryIsEmpty, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibility}}">
                    <FontIcon Glyph="&#xE7FC;" FontSize="48"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="No games yet" HorizontalAlignment="Center"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Pull down to refresh, or run a scan from Settings to load your library."
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Empty state: games exist but filters hide them all -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12" MaxWidth="320"
                            Visibility="{x:Bind _appVm.HasNoVisibleGames, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibility}}">
                    <FontIcon Glyph="&#xE71C;" FontSize="48"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="No games match your filters" HorizontalAlignment="Center"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Try adjusting your search, platform toggles, or filters."
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button Content="Reset filters" HorizontalAlignment="Center"
                            Click="ResetFilters_Click"/>
                </StackPanel>
            </Grid>
        </RefreshContainer>
    </utu:LoadingView>
</Page>
