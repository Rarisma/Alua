<Page
    x:Class="Alua.UI.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls1="clr-namespace:Alua.UI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:data="clr-namespace:Alua.Models"
    mc:Ignorable="android"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Defined per-page (not app-level): Uno does not reliably resolve a {StaticResource}
             referenced inside a page-level DataTemplate up to Application.Resources. -->
        <controls1:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <controls1:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <controls1:HoursToTimeTextConverter x:Key="HoursToTimeTextConverter"/>
        <DataTemplate x:Key="AchievementTemplate" x:DataType="data:Achievement">
            <Grid Margin="10" Opacity="{x:Bind IsUnlocked, Converter={StaticResource BoolToOpacityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="50" Height="50" CornerRadius="12" Background="Transparent"
                        Margin="0,0,10,0" VerticalAlignment="Center">
                    <controls1:CachedImage UriSource="{x:Bind IconUri}" DecodePixelWidth="50" DecodePixelHeight="50" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="{x:Bind Title}" FontSize="20" TextWrapping="Wrap"
                               MaxLines="2" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap" Margin="0,5,0,0"
                               MaxLines="3" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Flags + Rarity -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4"
                            HorizontalAlignment="Right">
                    <!-- Missable badge (only providers that classify achievements set this) -->
                    <Border Visibility="{x:Bind IsMissable, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                            CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                        <TextBlock Text="Missable"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                    </Border>
                    <!-- Rarity percentage if available -->
                    <TextBlock HorizontalAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind HasRarity, Converter={StaticResource BoolToVisibility}}">
                        <Run Text="{x:Bind RarityPercentageText}"/><Run Text="%"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>
    <RefreshContainer RefreshRequested="{x:Bind Refresh}">

        <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon -->
            <Border Grid.Column="0" Width="200" Height="100" Margin="10"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <controls1:CachedImage UriSource="{x:Bind AppVM.SelectedGame.IconUri, Mode=OneWay}"
                                       DecodePixelWidth="64" DecodePixelHeight="64" Stretch="Uniform"/>
            </Border>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left side content -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Image Source="{x:Bind AppVM.SelectedGame.ProviderImage, Mode=OneWay}" Height="20" Stretch="Uniform"
                               HorizontalAlignment="Center" Margin="0,0,10,0"/>

                        <!-- Game Title -->
                        <TextBlock Text="{x:Bind AppVM.SelectedGame.Name, Mode=OneWay}" FontSize="24" TextWrapping="Wrap" />

                        <!-- Refresh button -->
                        <Button Visibility="Visible" android:Visibility="Collapsed" Click="{x:Bind Refresh}"
                                AutomationProperties.Name="Refresh"
                                ToolTipService.ToolTip="Refresh"
                                Margin="10,0,0,0">
                            <SymbolIcon Symbol="Refresh"/>
                        </Button>
                    </StackPanel>

                    <!-- Current Playtime -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                Visibility="{x:Bind AppVM.SelectedGame.HasPlaytime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Playtime: " FontSize="14" TextWrapping="Wrap" />
                        <TextBlock Text="{x:Bind AppVM.SelectedGame.PlaytimeText, Mode=OneWay}" FontSize="14" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Achievement Count / Status -->
                    <TextBlock Grid.Row="2" Text="{x:Bind AppVM.SelectedGame.StatusText, Mode=OneWay}" VerticalAlignment="Center"
                               Margin="0,0,10,5"/>

                    <!-- Progress Bar -->
                    <ProgressBar Grid.Row="3" Minimum="0" HorizontalAlignment="Left" Margin="0,0,10,0"
                        Maximum="{x:Bind AppVM.SelectedGame.Achievements.Count, Mode=OneWay}"  Width="150" Height="10"
                        VerticalAlignment="Center" Value="{x:Bind AppVM.SelectedGame.UnlockedCount, Mode=OneWay}"
                        Visibility="{x:Bind AppVM.SelectedGame.HasAchievements, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>

                <!-- Right side - HowLongToBeat Times -->
                <Grid Grid.Column="1" Margin="20,0,0,0"
                      Visibility="{x:Bind AppVM.SelectedGame.HasHowLongToBeatData, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Story Time -->
                    <TextBlock Grid.Row="0" Text="Story" FontWeight="Bold" FontSize="14" />
                    <TextBlock Grid.Row="1" Text="{x:Bind AppVM.SelectedGame.HowLongToBeatMain, Mode=OneWay,
                         Converter={StaticResource HoursToTimeTextConverter}}" FontSize="14" Margin="0,0,0,10" />

                    <!-- 100% Time -->
                    <TextBlock Grid.Row="2" Text="100%" FontWeight="Bold" FontSize="14" />
                    <TextBlock Grid.Row="3" Text="{x:Bind AppVM.SelectedGame.HowLongToBeatCompletionist,
                        Mode=OneWay, Converter={StaticResource HoursToTimeTextConverter}}" FontSize="14" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <CheckBox x:Name="CheckShowUnlocked" Content="Show Unlocked" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="CheckShowLocked" Content="Show Locked" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="CheckHideHidden" Content="Hide Secret Achievements" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="CheckMissableOnly" Content="Missable Only" IsChecked="False" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
        </StackPanel>

        <!-- Achievements List -->
        <ScrollViewer x:Name="achievementsScrollViewer" Grid.Row="2" Margin="0,10,0,0">
            <ItemsRepeater ItemsSource="{x:Bind FilteredAchievements, Mode=OneWay}"
                           ItemTemplate="{StaticResource AchievementTemplate}"
                           HorizontalAlignment="Stretch">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="0"/>
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
    </RefreshContainer>
</Page>
