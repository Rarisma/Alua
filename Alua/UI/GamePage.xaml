<Page
    x:Class="Alua.UI.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls1="clr-namespace:Alua.UI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:data="clr-namespace:Alua.Models"
    mc:Ignorable="android"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Defined per-page (not app-level): Uno does not reliably resolve a {StaticResource}
             referenced inside a page-level DataTemplate up to Application.Resources. -->
        <controls1:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <controls1:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <controls1:HoursToTimeTextConverter x:Key="HoursToTimeTextConverter"/>
        <controls1:TrophyTypeToBrushConverter x:Key="TrophyTypeToBrush"/>
        <DataTemplate x:Key="AchievementTemplate" x:DataType="data:Achievement">
            <Grid Margin="10" Opacity="{x:Bind IsUnlocked, Converter={StaticResource BoolToOpacityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="50" Height="50" CornerRadius="12" Background="Transparent"
                        Margin="0,0,10,0" VerticalAlignment="Center">
                    <Grid>
                        <controls1:CachedImage UriSource="{x:Bind IconUri}" DecodePixelWidth="50" DecodePixelHeight="50" Stretch="UniformToFill"/>
                        <!-- PSN trophy-tier badge (PSN-only; other providers leave TrophyKind.None) -->
                        <Border Width="18" Height="18" CornerRadius="9"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,-4,-4"
                                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                ToolTipService.ToolTip="{x:Bind TrophyTypeText}"
                                Visibility="{x:Bind HasTrophy, Converter={StaticResource BoolToVisibility}}">
                            <Ellipse Width="10" Height="10"
                                     Fill="{x:Bind TrophyType, Converter={StaticResource TrophyTypeToBrush}}"/>
                        </Border>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="{x:Bind Title}" FontSize="20" TextWrapping="Wrap"
                               MaxLines="2" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap" Margin="0,5,0,0"
                               MaxLines="3" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Extra's-->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4"
                            HorizontalAlignment="Right">

                    <!-- RA convo link-->
                    <Button Background="Transparent" Click="OpenRAConvoClick" Tag="{x:Bind Id}"
                            Visibility="{x:Bind IsRA, Converter={StaticResource BoolToVisibility}}">
                        <SymbolIcon Symbol="Message"/>
                    </Button>

                    <!-- Missable badge (only providers that classify achievements set this) -->
                    <Border Visibility="{x:Bind IsMissable, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                            CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                        <TextBlock Text="Missable"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                    </Border>
                    <!-- Rarity percentage if available -->
                    <TextBlock HorizontalAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind HasRarity, Converter={StaticResource BoolToVisibility}}">
                        <Run Text="{x:Bind RarityPercentageText}"/><Run Text="%"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>
    <RefreshContainer RefreshRequested="{x:Bind Refresh}">

        <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon -->
            <Border Grid.Column="0" Width="200" Height="100" Margin="10"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <controls1:CachedImage UriSource="{x:Bind CurrentEdition.IconUri, Mode=OneWay}"
                                       DecodePixelWidth="64" DecodePixelHeight="64" Stretch="Uniform"/>
            </Border>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left side content -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Image Source="{x:Bind CurrentEdition.ProviderImage, Mode=OneWay}" Height="20" Stretch="Uniform"
                               HorizontalAlignment="Center" Margin="0,0,10,0"/>

                        <!-- Game Title (group name when editions are merged) -->
                        <TextBlock Text="{x:Bind AppVM.SelectedGame.DisplayName, Mode=OneWay}" FontSize="24" TextWrapping="Wrap" />

                        <!-- Refresh button -->
                        <Button Visibility="Visible" android:Visibility="Collapsed" Click="{x:Bind Refresh}"
                                AutomationProperties.Name="Refresh"
                                ToolTipService.ToolTip="Refresh"
                                Margin="10,0,0,0">
                            <SymbolIcon Symbol="Refresh"/>
                        </Button>
                    </StackPanel>

                    <!-- Current Playtime -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                Visibility="{x:Bind CurrentEdition.HasPlaytime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Playtime: " FontSize="14" TextWrapping="Wrap" />
                        <TextBlock Text="{x:Bind CurrentEdition.PlaytimeText, Mode=OneWay}" FontSize="14" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Achievement Count / Status -->
                    <TextBlock Grid.Row="2" Text="{x:Bind CurrentEdition.StatusText, Mode=OneWay}" VerticalAlignment="Center"
                               Margin="0,0,10,5"/>

                    <!-- Progress Bar -->
                    <ProgressBar Grid.Row="3" Minimum="0" HorizontalAlignment="Left" Margin="0,0,10,0"
                        Maximum="{x:Bind CurrentEdition.Achievements.Count, Mode=OneWay}"  Width="150" Height="10"
                        VerticalAlignment="Center" Value="{x:Bind CurrentEdition.UnlockedCount, Mode=OneWay}"
                        Visibility="{x:Bind CurrentEdition.HasAchievements, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>

                <!-- Right side - HowLongToBeat Times -->
                <Grid Grid.Column="1" Margin="20,0,0,0"
                      Visibility="{x:Bind CurrentEdition.HasHowLongToBeatData, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Story Time -->
                    <TextBlock Grid.Row="0" Text="Story" FontWeight="Bold" FontSize="14" />
                    <TextBlock Grid.Row="1" Text="{x:Bind CurrentEdition.HowLongToBeatMain, Mode=OneWay,
                         Converter={StaticResource HoursToTimeTextConverter}}" FontSize="14" Margin="0,0,0,10" />

                    <!-- 100% Time -->
                    <TextBlock Grid.Row="2" Text="100%" FontWeight="Bold" FontSize="14" />
                    <TextBlock Grid.Row="3" Text="{x:Bind CurrentEdition.HowLongToBeatCompletionist,
                        Mode=OneWay, Converter={StaticResource HoursToTimeTextConverter}}" FontSize="14" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Edition tabs (only when this card merges several editions / subsets) -->
        <ListView x:Name="EditionTabs" Grid.Row="1"
                  Margin="0,8,0,0"
                  SelectionMode="Single"
                  SelectionChanged="EditionTabs_SelectionChanged"
                  Visibility="{x:Bind AppVM.SelectedGame.IsMerged, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                  ItemsSource="{x:Bind AppVM.SelectedGame.Editions, Mode=OneWay}"
                  ScrollViewer.HorizontalScrollMode="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollMode="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="data:Game">
                    <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,2">
                        <Image Source="{x:Bind ProviderImage}" Height="16" Width="16" Stretch="Uniform"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind EditionLabel}" VerticalAlignment="Center"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Filters -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <CheckBox x:Name="CheckShowUnlocked" Content="Show Unlocked" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="CheckShowLocked" Content="Show Locked" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="CheckHideHidden" Content="Hide Secret Achievements" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <CheckBox x:Name="CheckMissableOnly" Content="Missable Only" IsChecked="False" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
        </StackPanel>

        <!-- Achievements List -->
        <ScrollViewer x:Name="achievementsScrollViewer" Grid.Row="3" Margin="0,10,0,0">
            <ItemsRepeater ItemsSource="{x:Bind FilteredAchievements, Mode=OneWay}"
                           ItemTemplate="{StaticResource AchievementTemplate}"
                           HorizontalAlignment="Stretch">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="0"/>
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
    </RefreshContainer>
</Page>
