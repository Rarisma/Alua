<Page x:Class="Alua.UI.ApiKeySetup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header / instructions -->
        <StackPanel Grid.Row="0" Padding="20,15" Spacing="5">
            <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold"/>
            <TextBlock x:Name="InstructionsText"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <!-- WebView -->
        <WebView2 x:Name="SetupWebView" Grid.Row="1"/>

        <!-- Footer: key input + buttons -->
        <Grid Grid.Row="2" Padding="20,10" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="ApiKeyBox" Grid.Column="0"
                     PlaceholderText="Paste your API key here"
                     Header="API Key"/>
            <Button Grid.Column="1" Content="Cancel" Click="{x:Bind OnCancel}" VerticalAlignment="Bottom"/>
            <Button Grid.Column="2" Content="Save" Style="{StaticResource AccentButtonStyle}"
                    Click="{x:Bind OnSave}" VerticalAlignment="Bottom"/>
            <ProgressRing Grid.Column="3" x:Name="Progress" IsActive="False"
                          Width="24" Height="24" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Page>
