<Page
    x:Class="Alua.UI.Initialize"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Alua.Helpers"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Spacing="20" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="Welcome to Alua!" FontSize="24" TextAlignment="Center" />
        <TextBlock Text="Please provide at least one account to get started." TextAlignment="Center" />

        <!-- Account input fields -->
        <Button Click="{x:Bind FRVM.SetupSteam}" Width="300">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Image Source="/Assets/Icons/steam.png" Width="24" Height="24" />
                <TextBlock Text="Steam" VerticalAlignment="Center"/>
                <TextBlock Text="Connected" VerticalAlignment="Center"
                           Visibility="{x:Bind FRVM.IsSteamConfigured, Mode=OneWay}"/>
            </StackPanel>
        </Button>

        <Button Click="{x:Bind FRVM.SetupRetro}" Width="300">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Image Source="/Assets/Icons/RetroAchievements.png" Width="24" Height="24" />
                <TextBlock Text="RetroAchievements" VerticalAlignment="Center"/>
                <TextBlock Text="Connected" VerticalAlignment="Center"
                           Visibility="{x:Bind FRVM.IsRetroConfigured, Mode=OneWay}"/>
            </StackPanel>
        </Button>


        <!-- PlayStation Network Authentication -->
        <Button Click="{x:Bind FRVM.AuthenticatePsn}" Width="300" Visibility="{x:Bind helpers:Platform.HideOnLinux}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Image Source="/Assets/Icons/PSN.png" Width="24" Height="24" />
                <TextBlock Text="PlayStation" VerticalAlignment="Center"/>
                <TextBlock Text="Connected" FontWeight="Bold" VerticalAlignment="Center"
                           Visibility="{x:Bind FRVM.IsPsnAuthenticated, Mode=OneWay}"/>
            </StackPanel>
        </Button>

        <!-- Xbox Live Authentication -->
        <Button Click="{x:Bind FRVM.AuthenticateXbox}" Width="300">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Image Source="/Assets/Icons/xbox.png" Width="24" Height="24" />

                <TextBlock Text="Xbox" VerticalAlignment="Center"/>
                <TextBlock Text="Connected" VerticalAlignment="Center"
                           Visibility="{x:Bind FRVM.IsXboxAuthenticated, Mode=OneWay}"/>
            </StackPanel>
        </Button>

        <!-- Error text -->
        <TextBlock Text="{x:Bind FRVM.ErrorMessage}" Foreground="Red"
                   Visibility="{x:Bind FRVM.HasError}" TextAlignment="Center" />
        <TextBlock Text="More providers can be configured later in settings." Foreground="Red"
                   FontStyle="Italic"
                   Visibility="{x:Bind FRVM.HasError}" TextAlignment="Center" />

        <Button Content="Continue" Click="{x:Bind FRVM.Continue}" HorizontalAlignment="Center"/>
    </StackPanel>
</Page>
