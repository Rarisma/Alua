<Page x:Class="Alua.UI.PSNLogin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="20,15" Spacing="5">
            <TextBlock Text="Sign in with PlayStation" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Sign in on the PlayStation Store below, then click Done."
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <!-- WebView -->
        <WebView2 x:Name="LoginWebView" Grid.Row="1"/>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Padding="20,10" Spacing="10">
            <Button Content="Cancel" Click="{x:Bind OnCancel}"/>
            <Button Content="Done" Style="{StaticResource AccentButtonStyle}" Click="{x:Bind OnDone}"/>
            <ProgressRing x:Name="Progress" IsActive="False" Width="24" Height="24" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
