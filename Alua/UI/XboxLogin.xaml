<Page x:Class="Alua.UI.XboxLogin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="20,15" Spacing="5">
            <TextBlock Text="Sign in with Xbox" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Sign in with your Microsoft account to connect Xbox Live."
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <!-- Sign-in area: the WebView2 is created in code-behind and added here,
             matching PSNLogin so the native control lifetime stays in code. -->
        <Grid x:Name="WebViewHost" Grid.Row="1"/>

        <!-- Footer -->
        <Grid Grid.Row="2" Padding="20,10" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Click="{x:Bind OnCancel}" VerticalAlignment="Bottom"/>
            <ProgressRing Grid.Column="2" x:Name="Progress" IsActive="True"
                          Width="24" Height="24" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Page>
